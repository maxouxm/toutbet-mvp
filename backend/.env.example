APP_NAME=ToutBet'
ENV=dev
DEBUG=true

# IMPORTANT: change in production
JWT_SECRET=dev-change-me-very-long-secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Used to sign audit logs (repudiation mitigation)
AUDIT_LOG_SECRET=dev-audit-log-secret-change-me

# SQLite
DATABASE_URL=sqlite:///./toutbet.db

# CORS
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Rate limit
RATE_LIMIT_DEFAULT=60/minute
